{
  "name": "@cycletime/project-service",
  "version": "1.0.0",
  "description": "Project lifecycle management service with team management, templates, analytics, and intelligent project insights",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts --no-warn-ignored",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cycletime/shared-types": "*",
    "@cycletime/shared-utils": "*",
    "@cycletime/shared-config": "*",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/multipart": "^8.0.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^9.3.0",
    "@fastify/swagger-ui": "^4.0.0",
    "bull": "^4.12.2",
    "fastify": "^5.4.0",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "redis": "^4.6.11",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bull": "^4.10.0",
    "@types/jest": "^29.5.8",
    "@types/lodash": "^4.14.202",
    "@types/node": "^20.10.5",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^8.37.0",
    "@typescript-eslint/parser": "^8.37.0",
    "eslint": "^9.31.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  },
  "keywords": [
    "project",
    "management",
    "lifecycle",
    "team",
    "templates",
    "analytics",
    "orchestration",
    "insights",
    "typescript"
  ],
  "author": "CycleTime Team",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "restricted"
  }
}