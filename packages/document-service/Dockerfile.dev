FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./
COPY packages/document-service/package*.json ./packages/document-service/

# Install dependencies
RUN npm ci

# Copy source code
COPY . .

# Build the package
RUN npm run build --workspace=@cycletime/document-service

# Expose the port
EXPOSE 8003

# Start the service
CMD ["npm", "run", "start", "--workspace=@cycletime/document-service"]