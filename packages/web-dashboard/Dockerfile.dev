FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./
COPY packages/web-dashboard/package*.json ./packages/web-dashboard/

# Install dependencies
RUN npm ci

# Copy source code
COPY . .

# Build the package
RUN npm run build --workspace=@cycletime/web-dashboard

# Expose the port
EXPOSE 3000

# Start the service
CMD ["npm", "run", "start", "--workspace=@cycletime/web-dashboard"]