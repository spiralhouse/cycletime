{
  "name": "@cycletime/web-dashboard",
  "version": "0.1.0",
  "description": "React-based web dashboard for CycleTime",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts --no-warn-ignored",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "dashboard",
    "react",
    "web",
    "cycletime"
  ],
  "author": "Spiral House",
  "license": "MIT",
  "dependencies": {
    "@cycletime/shared-types": "*",
    "@fastify/cors": "^11.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.0.1",
    "@fastify/static": "^8.0.1",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@fastify/view": "^10.0.1",
    "fastify": "^5.4.0",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.5",
    "@typescript-eslint/eslint-plugin": "^8.37.0",
    "@typescript-eslint/parser": "^8.37.0",
    "eslint": "^9.31.0",
    "jest": "^29.7.0",
    "pino-pretty": "^11.2.2",
    "ts-jest": "^29.1.1",
    "tsx": "^3.12.7",
    "typescript": "^5.8.3"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "restricted"
  }
}