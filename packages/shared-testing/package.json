{
  "name": "@cycletime/shared-testing",
  "version": "0.1.0",
  "description": "Shared contract testing framework and utilities for CycleTime monorepo",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "private": true,
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts --no-warn-ignored",
    "lint:fix": "eslint src/**/*.ts --fix --no-warn-ignored",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "contract-testing",
    "api-validation",
    "openapi",
    "asyncapi",
    "testing-framework"
  ],
  "author": "John Burbridge",
  "license": "AGPL-3.0-or-later",
  "dependencies": {
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "@apidevtools/swagger-parser": "^10.1.0",
    "@asyncapi/parser": "^3.0.0",
    "supertest": "^6.3.3",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/supertest": "^2.0.12",
    "@types/js-yaml": "^4.0.5",
    "@types/jest": "^29.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0",
    "eslint": "^9.31.0"
  },
  "peerDependencies": {
    "jest": "^29.0.0"
  }
}