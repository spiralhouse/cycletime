{
  "name": "@cycletime/notification-service",
  "version": "1.0.0",
  "description": "Multi-channel notification service supporting email, SMS, push, and in-app notifications with template management",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts --no-warn-ignored",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cycletime/shared-types": "^1.0.0",
    "@cycletime/shared-utils": "^1.0.0",
    "@cycletime/shared-config": "^1.0.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^9.3.0",
    "@fastify/swagger-ui": "^4.0.0",
    "@firebase/messaging": "^0.12.8",
    "fastify": "^5.4.0",
    "nodemailer": "^6.9.7",
    "twilio": "^4.19.0",
    "winston": "^3.11.0",
    "redis": "^4.6.11",
    "bull": "^4.12.2",
    "handlebars": "^4.7.8",
    "zod": "^3.22.4",
    "moment": "^2.29.4",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.5",
    "@types/nodemailer": "^6.4.14",
    "@types/bull": "^4.10.0",
    "@types/handlebars": "^4.1.0",
    "@types/lodash": "^4.14.200",
    "@typescript-eslint/eslint-plugin": "^8.37.0",
    "@typescript-eslint/parser": "^8.37.0",
    "eslint": "^9.31.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  },
  "keywords": [
    "notifications",
    "email",
    "sms",
    "push-notifications",
    "in-app",
    "templates",
    "delivery-tracking",
    "multi-channel",
    "twilio",
    "nodemailer",
    "firebase",
    "typescript"
  ],
  "author": "CycleTime Team",
  "license": "MIT"
}