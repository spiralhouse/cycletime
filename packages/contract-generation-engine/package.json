    "@cycletime/shared-types": "^1.0.0",
    "@cycletime/shared-utils": "^1.0.0",
    "ajv": "^8.12.0",
    "fastify": "^5.4.0",
    "js-yaml": "^4.1.0",
    "openai": "^4.28.0",
    "openapi-types": "^12.1.3",
    "redis": "^4.6.11",
    "swagger-jsdoc": "^6.2.8",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.0.0",
    "@asyncapi/parser": "^3.4.0",
    "@fastify/cors": "^10.1.0",
    "@fastify/helmet": "^12.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@types/jest": "^29.5.8",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.5",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@typescript-eslint/eslint-plugin": "^8.37.0",
    "@typescript-eslint/parser": "^8.37.0",
    "eslint": "^9.31.0",
    "jest": "^29.7.0",
    "jest-openapi": "^0.14.2",
    "supertest": "^7.1.3",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
