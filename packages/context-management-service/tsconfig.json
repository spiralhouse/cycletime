{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@cycletime/shared-types": ["../shared-types/src"],
      "@cycletime/shared-utils": ["../shared-utils/src"],
      "@cycletime/shared-config": ["../shared-config/src"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts"],
  "references": [
    { "path": "../shared-types" },
    { "path": "../shared-utils" },
    { "path": "../shared-config" }
  ]
}