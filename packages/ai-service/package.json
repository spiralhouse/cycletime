{
  "name": "@cycletime/ai-service",
  "version": "1.0.0",
  "description": "AI service with provider abstraction layer for CycleTime",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:unit": "jest --testPathIgnorePatterns=contract --testPathIgnorePatterns=integration",
    "test:integration": "jest --testPathPattern=integration",
    "test:contract": "jest --testPathPattern=contract",
    "test:all": "jest && npm run test:contract",
    "lint": "eslint src/**/*.ts --no-warn-ignored",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.56.0",
    "@cycletime/shared-utils": "^1.0.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@fastify/type-provider-typebox": "^5.2.0",
    "@prisma/client": "^6.12.0",
    "fastify": "^5.4.0",
    "prisma": "^6.12.0",
    "redis": "^4.6.11",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.5",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.37.0",
    "@typescript-eslint/parser": "^8.37.0",
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "eslint": "^9.31.0",
    "jest": "^29.7.0",
    "js-yaml": "^4.1.0",
    "supertest": "^7.0.0",
    "swagger-parser": "^10.0.3",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  },
  "keywords": [
    "ai",
    "anthropic",
    "claude",
    "provider-abstraction",
    "typescript"
  ],
  "author": "CycleTime Team",
  "license": "MIT"
}
