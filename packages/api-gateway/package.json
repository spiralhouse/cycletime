{
  "name": "@cycletime/api-gateway",
  "version": "1.0.0",
  "description": "CycleTime API Gateway - Unified entry point with authentication, authorization, rate limiting, and service routing",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:verbose": "jest --verbose",
    "test:debug": "jest --detectOpenHandles --forceExit --verbose",
    "test:auth": "jest --testNamePattern=\"Authentication\"",
    "test:circuit": "jest --testNamePattern=\"Circuit\"",
    "test:integration": "jest --testPathPattern=\"integration\"",
    "test:contract": "jest --testPathPattern=\"contract\"",
    "test:unit": "jest --testPathIgnorePatterns=\"contract\"",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:local-ci": "act --container-architecture linux/amd64 -j test --artifact-server-path /tmp/artifacts",
    "lint": "eslint src/**/*.ts --no-warn-ignored",
    "lint:fix": "eslint src/**/*.ts --fix --no-warn-ignored",
    "typecheck": "tsc --noEmit",
    "quality": "npm run lint && npm run typecheck && npm run test",
    "quality:ci": "npm run lint && npm run typecheck && npm run test:ci",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@cycletime/shared-types": "^1.0.0",
    "@cycletime/shared-utils": "^1.0.0",
    "@cycletime/shared-config": "^1.0.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^7.2.4",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/http-proxy": "^9.3.0",
    "fastify": "^4.26.2",
    "zod": "^3.22.4",
    "winston": "^3.11.0",
    "redis": "^4.6.11",
    "consul": "^0.40.0",
    "etcd3": "^1.1.2",
    "node-fetch": "^3.3.2",
    "pino": "^8.19.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.5",
    "@types/node-fetch": "^2.6.4",
    "@typescript-eslint/eslint-plugin": "^8.37.0",
    "@typescript-eslint/parser": "^8.37.0",
    "eslint": "^9.31.0",
    "jest": "^29.7.0",
    "js-yaml": "^4.1.0",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  },
  "keywords": [
    "api-gateway",
    "fastify",
    "authentication",
    "authorization",
    "rate-limiting",
    "service-discovery",
    "load-balancing",
    "microservices",
    "cycletime"
  ],
  "author": "CycleTime Team",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "restricted"
  }
}
