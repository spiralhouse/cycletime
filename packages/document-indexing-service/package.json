    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts --no-warn-ignored",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cycletime/shared-types": "^1.0.0",
    "@cycletime/shared-utils": "^1.0.0",
    "@cycletime/shared-config": "^1.0.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "fastify": "^5.4.0",
    "zod": "^3.22.4",
    "winston": "^3.11.0",
    "redis": "^4.6.11",
    "tiktoken": "^1.0.10",
    "openai": "^4.28.0",
    "@pinecone-database/pinecone": "^6.1.1",
    "chromadb": "^1.7.3",
    "langchain": "^0.1.25",
    "natural": "^6.10.0",
    "stopword": "^2.0.8",
    "compromise": "^14.10.0",
    "pdf-parse": "^1.1.1",
    "mammoth": "^1.6.0",
    "yauzl": "^2.10.0",
    "cheerio": "^1.0.0-rc.12"
