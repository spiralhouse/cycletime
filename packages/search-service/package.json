{
  "name": "@cycletime/search-service",
  "version": "1.0.0",
  "description": "Global search service with Elasticsearch integration for comprehensive entity search across CycleTime",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts --no-warn-ignored",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cycletime/shared-types": "^1.0.0",
    "@cycletime/shared-utils": "^1.0.0",
    "@cycletime/shared-config": "^1.0.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^9.3.0",
    "@fastify/swagger-ui": "^4.0.0",
    "fastify": "^5.4.0",
    "elasticsearch": "^16.7.3",
    "@elastic/elasticsearch": "^8.11.0",
    "redis": "^4.6.11",
    "winston": "^3.11.0",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.5",
    "@types/elasticsearch": "^5.0.40",
    "@types/lodash": "^4.14.200",
    "@typescript-eslint/eslint-plugin": "^8.37.0",
    "@typescript-eslint/parser": "^8.37.0",
    "eslint": "^9.31.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  },
  "keywords": [
    "search",
    "elasticsearch",
    "indexing",
    "faceted-search",
    "full-text-search",
    "global-search",
    "search-analytics",
    "typescript"
  ],
  "author": "CycleTime Team",
  "license": "MIT"
}