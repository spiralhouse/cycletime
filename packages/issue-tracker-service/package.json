{
  "name": "@cycletime/issue-tracker-service",
  "version": "1.0.0",
  "description": "Multi-platform issue tracking service for Linear, GitHub, and Jira integration",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch --passWithNoTests",
    "lint": "eslint src/**/*.ts --no-warn-ignored",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cycletime/shared-types": "^1.0.0",
    "@cycletime/shared-utils": "^1.0.0",
    "@cycletime/shared-config": "^1.0.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@linear/sdk": "^15.0.0",
    "@octokit/rest": "^20.0.2",
    "fastify": "^5.4.0",
    "zod": "^3.22.4",
    "winston": "^3.11.0",
    "redis": "^4.6.11",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.5",
    "@typescript-eslint/eslint-plugin": "^8.37.0",
    "@typescript-eslint/parser": "^8.37.0",
    "eslint": "^9.31.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  },
  "keywords": [
    "issue-tracking",
    "linear",
    "github",
    "jira",
    "multi-platform",
    "project-management"
  ],
  "author": "CycleTime Team",
  "license": "MIT"
}