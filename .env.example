# CycleTime Development Environment Configuration
# Copy this file to .env and update with your specific values

# Node.js Environment
NODE_ENV=development
LOG_LEVEL=debug

# Database Configuration
POSTGRES_DB=cycletime_dev
POSTGRES_USER=cycletime
POSTGRES_PASSWORD=development_password
POSTGRES_PORT=5432

# Redis Configuration
REDIS_PORT=6379

# MinIO Configuration (S3-compatible object storage)
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# API Service Ports
API_PORT=8000
WEB_PORT=3000
MCP_PORT=8001
CLAUDE_SERVICE_PORT=8002
DOCUMENT_SERVICE_PORT=8003
TASK_SERVICE_PORT=8004

# Development Tool Ports
ADMINER_PORT=8080
REDIS_INSIGHT_PORT=8081

# External API Keys (Development)
# Replace with your actual development API keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
LINEAR_API_KEY=your_linear_api_key_here
GITHUB_TOKEN=your_github_token_here

# Development Flags
ENABLE_MOCK_AI=true
ENABLE_DEBUG_LOGGING=true
ENABLE_HOT_RELOAD=true

# Database URLs (auto-generated from above values)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}
REDIS_URL=redis://localhost:${REDIS_PORT}